generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  FACILITATOR
  SCHOOL_ADMIN
}

enum UserStatus {
  PENDING
  ACTIVE
  DISABLED
}

enum SchoolStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum AssignmentStatus {
  ACTIVE
  ENDED
  PAUSED
}

enum SessionStatus {
  NOT_STARTED
  ONGOING
  COMPLETED
  MISSED
  RESCHEDULED
  CANCELLED
  FOR_VERIFICATION
}

enum InventoryCondition {
  NEW
  GOOD
  FAIR
  NEEDS_REPLACEMENT
  LOST
}

enum ReportStatus {
  DRAFT
  SUBMITTED
  REVIEWED
  RETURNED
}

enum ProjectStatus {
  NOT_STARTED
  IN_PROGRESS
  SUBMITTED
  CHECKED
  NEEDS_REVISION
  COMPLETED
}

model Profile {
  id        String     @id @default(uuid())
  email     String     @unique
  fullName  String
  role      UserRole   @default(FACILITATOR)
  status    UserStatus @default(PENDING)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  facilitatorAssignments FacilitatorAssignment[] @relation("FacilitatorAssignments")
  facilitatedSessions    ACESession[]            @relation("FacilitatorSessions")
  reports                Report[]                @relation("ReportFacilitator")
  mediaUploads           MediaUpload[]           @relation("MediaUploader")
}

model School {
  id            String       @id @default(uuid())
  name          String
  address       String
  contactPerson String
  contactEmail  String?
  schoolYear    String
  status        SchoolStatus @default(ACTIVE)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  assignments    FacilitatorAssignment[]
  sessions       ACESession[]
  projects       ACEProject[]
  inventoryItems InventoryItem[]
  reports        Report[]
  mediaUploads   MediaUpload[]
}

model FacilitatorAssignment {
  id            String           @id @default(uuid())
  facilitatorId String
  schoolId      String
  startDate     DateTime
  endDate       DateTime?
  status        AssignmentStatus @default(ACTIVE)

  facilitator Profile @relation("FacilitatorAssignments", fields: [facilitatorId], references: [id], onDelete: Restrict)
  school      School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([facilitatorId])
  @@index([schoolId])
}

model ACESession {
  id            String        @id @default(uuid())
  schoolId      String
  facilitatorId String
  title         String
  gradeLevel    String
  section       String
  sessionNumber Int
  scheduledDate DateTime
  actualDate    DateTime?
  status        SessionStatus @default(NOT_STARTED)
  remarks       String?
  sourceKey     String?       @unique
  sourceSheet   String?
  period        String?
  subject       String?
  teacher       String?
  activity      String?
  delivery      String?
  completion    String?
  updatedAt     DateTime      @updatedAt

  school      School           @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  facilitator Profile          @relation("FacilitatorSessions", fields: [facilitatorId], references: [id], onDelete: Restrict)
  progress    SessionProgress?
  projects    ACEProject[]
  reports     Report[]
  media       MediaUpload[]

  @@index([schoolId])
  @@index([facilitatorId])
  @@index([scheduledDate])
}

model ACEProject {
  id            String        @id @default(uuid())
  schoolId      String
  sessionId     String?
  title         String
  term          String?
  gradeLevel    String?
  section       String?
  students      String?
  teacher       String?
  projectType   String?
  description   String?
  projectUrl    String?
  remarks       String?
  submittedAt   DateTime?
  status        ProjectStatus @default(SUBMITTED)
  sourceKey     String?       @unique
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  school  School      @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  session ACESession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([schoolId])
  @@index([sessionId])
  @@unique([schoolId, title, gradeLevel, section])
}

model SessionProgress {
  id                   String  @id @default(uuid())
  sessionId            String  @unique
  skillCovered         String
  activityCompleted    Boolean @default(false)
  studentAttendance    Int
  completionPercentage Int
  issuesEncountered    String?
  nextSteps            String?

  session ACESession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model InventoryItem {
  id            String             @id @default(uuid())
  schoolId      String
  itemName      String
  category      String
  quantity      Int
  unit          String?
  condition     InventoryCondition @default(GOOD)
  remarks       String?
  sourceKey     String?            @unique
  lastCheckedAt DateTime?
  lastCheckedBy String?

  school          School                   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  checks          InventoryCheck[]
  remarkHistories InventoryRemarkHistory[]

  @@index([schoolId])
}

model InventoryCheck {
  id        String             @id @default(uuid())
  itemId    String
  checkedBy String
  condition InventoryCondition
  quantity  Int
  remarks   String?
  checkedAt DateTime           @default(now())

  item InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId])
}

model InventoryRemarkHistory {
  id         String   @id @default(uuid())
  itemId     String
  updatedBy  String
  oldRemarks String?
  newRemarks String?
  createdAt  DateTime @default(now())

  item InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId])
}

model Report {
  id            String       @id @default(uuid())
  schoolId      String
  facilitatorId String
  sessionId     String?
  reportType    String
  title         String
  summary       String
  submittedAt   DateTime?
  status        ReportStatus @default(DRAFT)

  school      School      @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  facilitator Profile     @relation("ReportFacilitator", fields: [facilitatorId], references: [id], onDelete: Restrict)
  session     ACESession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([schoolId])
  @@index([facilitatorId])
  @@index([sessionId])
}

model MediaUpload {
  id           String   @id @default(uuid())
  schoolId     String
  sessionId    String?
  uploadedById String
  fileName     String
  fileUrl      String
  fileType     String
  description  String?
  createdAt    DateTime @default(now())

  school     School      @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  session    ACESession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  uploadedBy Profile     @relation("MediaUploader", fields: [uploadedById], references: [id], onDelete: Restrict)

  @@index([schoolId])
  @@index([sessionId])
  @@index([uploadedById])
}
