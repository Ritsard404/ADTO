generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  FACILITATOR
  SCHOOL_ADMIN
}

enum UserStatus {
  PENDING
  ACTIVE
  DISABLED
}

enum SchoolYearStatus {
  OPEN
  CLOSED
  ARCHIVED
}

enum SchoolStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum AssignmentStatus {
  ACTIVE
  COMPLETED
  TRANSFERRED
}

enum SessionStatus {
  NOT_STARTED
  ONGOING
  COMPLETED
  MISSED
  RESCHEDULED
  CANCELLED
  FOR_VERIFICATION
}

enum InventoryCondition {
  NEW
  GOOD
  FAIR
  NEEDS_REPLACEMENT
  LOST
}

enum InventoryAssetStatus {
  AVAILABLE
  ASSIGNED
  MAINTENANCE
  LOST
  RETIRED
}

enum ReportStatus {
  DRAFT
  SUBMITTED
  REVIEWED
  RETURNED
}

enum ProjectStatus {
  NOT_STARTED
  IN_PROGRESS
  SUBMITTED
  CHECKED
  NEEDS_REVISION
  COMPLETED
}

enum SchoolMembershipRole {
  PRINCIPAL
  SCHOOL_ADMIN
  DEPARTMENT_HEAD
  FACULTY_LEAD
  COORDINATOR
  VIEWER
}

enum SchoolMembershipStatus {
  INVITED
  ACTIVE
  DISABLED
  ENDED
}

model Profile {
  id        String     @id @default(uuid())
  email     String     @unique
  fullName  String
  role      UserRole   @default(FACILITATOR)
  status    UserStatus @default(PENDING)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  facilitatorAssignments FacilitatorAssignment[] @relation("FacilitatorAssignments")
  facilitatedSessions    ACESession[]            @relation("FacilitatorSessions")
  reports                Report[]                @relation("ReportFacilitator")
  mediaUploads           MediaUpload[]           @relation("MediaUploader")
  schoolMemberships      SchoolMembership[]
}

model School {
  id                  String       @id @default(uuid())
  name                String
  address             String
  contactPerson       String
  contactEmail        String?
  contactNumber       String?
  schoolCode          String?
  schoolType          String?
  region              String?
  division            String?
  schoolYear          String
  adoptionYear        String?
  implementationYear  String?
  adoptionType        String?
  deployedFormId      String?
  formNumber          String?
  sourceSchoolId      String?
  schoolLogoFileId    String?
  team                String?
  unitHead            String?
  supervisor          String?
  supervisorEmail     String?
  edtechSpecialist    String?
  edtechEmail         String?
  gradeLevelAdoption  String?
  adoptionRemarks     String?
  addressLine1        String?
  addressLine2        String?
  scheduleArrangement String?
  codingModality      String?
  hardwareAllocation  String?
  softwareAllocation  String?
  status              SchoolStatus @default(ACTIVE)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  assignments        FacilitatorAssignment[]
  sessions           ACESession[]
  projects           ACEProject[]
  inventoryItems     InventoryItem[]
  reports            Report[]
  scheduleTemplates  ScheduleTemplate[]
  reportHistories    ReportHistory[]
  schoolYears        SchoolYear[]
  sections           SchoolSection[]
  teacherAssignments TeacherAssignment[]
  remarks            SchoolRemark[]
  reportNarratives   ReportNarrative[]
  mediaUploads       MediaUpload[]
  memberships        SchoolMembership[]

  @@unique([schoolCode])
  @@unique([deployedFormId])
  @@unique([sourceSchoolId])
}

model SchoolMembership {
  id               String                 @id @default(uuid())
  schoolId         String
  profileId        String
  roleLabel        SchoolMembershipRole   @default(SCHOOL_ADMIN)
  status           SchoolMembershipStatus @default(ACTIVE)
  invitationStatus String                 @default("ACCEPTED")
  startDate        DateTime               @default(now())
  endDate          DateTime?
  notes            String?
  createdBy        String?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  school  School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([schoolId, profileId])
  @@index([schoolId])
  @@index([profileId])
}

model ScheduleTemplate {
  id             String   @id @default(uuid())
  schoolId       String
  name           String
  dayOfWeek      Int
  startTime      String
  durationHours  Decimal  @default(1)
  gradeLevel     String
  section        String
  subject        String?
  teacher        String?
  facilitatorId  String?
  delivery       String?
  activity       String?
  defaultTopic   String?
  defaultRemarks String?
  isActive       Boolean  @default(true)
  createdById    String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, name])
  @@index([schoolId])
  @@index([createdById])
}

model SchoolYear {
  id        String           @id @default(uuid())
  schoolId  String
  label     String
  startDate DateTime?
  endDate   DateTime?
  status    SchoolYearStatus @default(OPEN)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, label])
  @@index([schoolId])
}

model SchoolSection {
  id             String   @id @default(uuid())
  schoolId       String
  schoolYear     String
  gradeLevel     String
  sectionName    String
  adviserName    String?
  maleStudents   Int      @default(0)
  femaleStudents Int      @default(0)
  totalStudents  Int      @default(0)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  school             School              @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  teacherAssignments TeacherAssignment[]

  @@unique([schoolId, schoolYear, gradeLevel, sectionName])
  @@index([schoolId])
}

model Teacher {
  id                 String    @id @default(uuid())
  fullName           String
  department         String?
  email              String?
  contactNumber      String?
  position           String?
  employmentStatus   String?
  sourceKey          String?   @unique
  sourceSheet        String?
  sourceWorkbookFile String?
  sourceRowRange     String?
  importedAt         DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  assignments TeacherAssignment[]

  @@index([sourceWorkbookFile])
}

model TeacherAssignment {
  id                   String    @id @default(uuid())
  teacherId            String
  schoolId             String
  sectionId            String?
  schoolYear           String
  gradeLevel           String
  subject              String
  sessionsParticipated Int       @default(0)
  hoursSupported       Decimal   @default(0)
  projectsFacilitated  Int       @default(0)
  attendanceRate       Int       @default(0)
  participationScore   Int       @default(0)
  sourceKey            String?   @unique
  sourceSheet          String?
  sourceWorkbookFile   String?
  sourceRowRange       String?
  sourceDeployedFormId String?
  importedAt           DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  teacher Teacher        @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  school  School         @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  section SchoolSection? @relation(fields: [sectionId], references: [id], onDelete: SetNull)

  @@index([schoolId])
  @@index([teacherId])
  @@index([schoolId, sourceWorkbookFile])
}

model ActivityCategory {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model SchoolRemark {
  id          String   @id @default(uuid())
  schoolId    String
  schoolYear  String
  period      String
  remarkType  String
  title       String
  details     String
  actionItems String?
  createdBy   String
  createdAt   DateTime @default(now())

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
}

model FacilitatorAssignment {
  id            String           @id @default(uuid())
  facilitatorId String
  schoolId      String
  startDate     DateTime
  endDate       DateTime?
  status        AssignmentStatus @default(ACTIVE)
  assignedBy    String?

  facilitator Profile @relation("FacilitatorAssignments", fields: [facilitatorId], references: [id], onDelete: Restrict)
  school      School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([facilitatorId])
  @@index([schoolId])
}

model ACESession {
  id                   String        @id @default(uuid())
  schoolId             String
  facilitatorId        String
  title                String
  gradeLevel           String
  section              String
  sessionNumber        Int
  scheduledDate        DateTime
  actualDate           DateTime?
  status               SessionStatus @default(NOT_STARTED)
  remarks              String?
  sourceKey            String?       @unique
  sourceSheet          String?
  sourceWorkbookFile   String?
  sourceRowRange       String?
  sourceDeployedFormId String?
  importedAt           DateTime?
  period               String?
  startTime            String?
  durationHours        Decimal?
  subject              String?
  teacher              String?
  activity             String?
  delivery             String?
  completion           String?
  updatedAt            DateTime      @updatedAt

  school      School           @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  facilitator Profile          @relation("FacilitatorSessions", fields: [facilitatorId], references: [id], onDelete: Restrict)
  progress    SessionProgress?
  projects    ACEProject[]
  reports     Report[]
  media       MediaUpload[]

  @@index([schoolId])
  @@index([facilitatorId])
  @@index([scheduledDate])
  @@index([schoolId, scheduledDate])
  @@index([facilitatorId, scheduledDate])
  @@index([schoolId, status])
}

model ACEProject {
  id                   String        @id @default(uuid())
  schoolId             String
  sessionId            String?
  title                String
  term                 String?
  gradeLevel           String?
  section              String?
  students             String?
  teacher              String?
  projectType          String?
  description          String?
  projectUrl           String?
  remarks              String?
  submittedAt          DateTime?
  status               ProjectStatus @default(SUBMITTED)
  sourceKey            String?       @unique
  sourceSheet          String?
  sourceWorkbookFile   String?
  sourceRowRange       String?
  sourceDeployedFormId String?
  importedAt           DateTime?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  school  School        @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  session ACESession?   @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  media   MediaUpload[]

  @@unique([schoolId, title, gradeLevel, section])
  @@index([schoolId])
  @@index([sessionId])
  @@index([schoolId, updatedAt])
}

model SessionProgress {
  id                   String  @id @default(uuid())
  sessionId            String  @unique
  skillCovered         String
  activityCompleted    Boolean @default(false)
  studentAttendance    Int
  completionPercentage Int
  issuesEncountered    String?
  nextSteps            String?

  session ACESession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model InventoryItem {
  id                    String               @id @default(uuid())
  schoolId              String
  itemName              String
  category              String
  quantity              Int
  issuedQuantity        Int?
  totalQuantity         Int?
  unit                  String?
  borrowedStatus        String?
  completenessStatus    String?
  facilitatorSignOff    String?
  condition             InventoryCondition   @default(GOOD)
  remarks               String?
  sourceKey             String?              @unique
  sourceSheet           String?
  sourceWorkbookFile    String?
  sourceRowRange        String?
  sourceDeployedFormId  String?
  importedAt            DateTime?
  assetNumber           String?
  deviceType            String?
  serialNumber          String?
  assignedFacilitatorId String?
  deploymentDate        DateTime?
  assetStatus           InventoryAssetStatus @default(ASSIGNED)
  lastCheckedAt         DateTime?
  lastCheckedBy         String?

  school          School                    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  checks          InventoryCheck[]
  remarkHistories InventoryRemarkHistory[]
  maintenanceLogs InventoryMaintenanceLog[]

  @@index([schoolId])
  @@index([schoolId, condition])
}

model InventoryMaintenanceLog {
  id         String   @id @default(uuid())
  itemId     String
  date       DateTime @default(now())
  issue      String
  resolution String?
  cost       Decimal?
  createdBy  String

  item InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId])
}

model InventoryCheck {
  id        String             @id @default(uuid())
  itemId    String
  checkedBy String
  condition InventoryCondition
  quantity  Int
  remarks   String?
  checkedAt DateTime           @default(now())

  item InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId])
}

model InventoryRemarkHistory {
  id         String   @id @default(uuid())
  itemId     String
  updatedBy  String
  oldRemarks String?
  newRemarks String?
  createdAt  DateTime @default(now())

  item InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId])
}

model Report {
  id            String       @id @default(uuid())
  schoolId      String
  facilitatorId String
  sessionId     String?
  reportType    String
  title         String
  summary       String
  submittedAt   DateTime?
  status        ReportStatus @default(DRAFT)

  school      School      @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  facilitator Profile     @relation("ReportFacilitator", fields: [facilitatorId], references: [id], onDelete: Restrict)
  session     ACESession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([schoolId])
  @@index([facilitatorId])
  @@index([sessionId])
}

model ReportHistory {
  id          String   @id @default(uuid())
  schoolId    String
  schoolYear  String
  reportType  String
  generatedBy String
  generatedAt DateTime @default(now())
  pptFileUrl  String
  pdfFileUrl  String

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([generatedBy])
  @@index([schoolId, generatedAt])
}

model ReportNarrative {
  id         String   @id @default(uuid())
  schoolId   String
  schoolYear String
  reportType String
  sectionKey String
  content    String
  updatedBy  String
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, schoolYear, reportType, sectionKey])
  @@index([schoolId])
}

model AuditLog {
  id            String   @id @default(uuid())
  actorId       String
  entityType    String
  entityId      String
  action        String
  previousValue String?
  newValue      String?
  createdAt     DateTime @default(now())

  @@index([actorId])
  @@index([entityType, entityId])
}

model ApprovalRequest {
  id          String    @id @default(uuid())
  entityType  String
  entityId    String
  action      String
  requestedBy String
  status      String    @default("PENDING")
  notes       String?
  decidedBy   String?
  decidedAt   DateTime?
  createdAt   DateTime  @default(now())

  @@index([entityType, entityId])
  @@index([requestedBy])
}

model MediaUpload {
  id             String    @id @default(uuid())
  schoolId       String
  sessionId      String?
  projectId      String?
  uploadedById   String
  fileName       String
  fileUrl        String
  fileType       String
  description    String?
  storageBucket  String?
  storagePath    String?
  fileSizeBytes  Int?
  mimeType       String?
  originalSource String    @default("EXTERNAL_LINK")
  uploadStatus   String    @default("LINKED")
  reviewStatus   String    @default("PENDING")
  teacherTag     String?
  gradeLevelTag  String?
  sectionTag     String?
  reportPeriod   String?
  verifiedAt     DateTime?
  verifiedBy     String?
  createdAt      DateTime  @default(now())

  school     School      @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  session    ACESession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  project    ACEProject? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  uploadedBy Profile     @relation("MediaUploader", fields: [uploadedById], references: [id], onDelete: Restrict)

  @@index([schoolId])
  @@index([sessionId])
  @@index([projectId])
  @@index([uploadedById])
  @@index([schoolId, createdAt])
  @@index([schoolId, reviewStatus])
  @@index([schoolId, reportPeriod])
}

model WorkbookImportBatch {
  id               String    @id @default(uuid())
  fileName         String
  checksum         String
  importedById     String
  facilitatorEmail String
  selectedSheets   String?
  status           String    @default("PENDING")
  rowsRead         Int       @default(0)
  rowsImported     Int       @default(0)
  rowsSkipped      Int       @default(0)
  sheetSummary     String?
  validationErrors String?
  schoolId         String?
  schoolName       String?
  errorMessage     String?
  createdAt        DateTime  @default(now())
  completedAt      DateTime?
  failedAt         DateTime?

  @@index([checksum])
  @@index([importedById])
  @@index([schoolId])
  @@index([createdAt])
}
